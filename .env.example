# .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Sabi DB (same server as this API) ─────────────────────────────────────────
SABI_DB_HOST=127.0.0.1
SABI_DB_PORT=3306
SABI_DB_NAME=sabi_db
SABI_DB_USER=sabi_api_user
SABI_DB_PASSWORD=your_sabi_db_password_here
SABI_DB_POOL_SIZE=5

# ── Enterprise DB (separate Contabo server) ───────────────────────────────────
ENTERPRISE_DB_HOST=your.enterprise.server.ip
ENTERPRISE_DB_PORT=3306
ENTERPRISE_DB_NAME=enterprise_db_name
ENTERPRISE_DB_USER=sabi_readonly_user
ENTERPRISE_DB_PASSWORD=your_enterprise_db_password_here
ENTERPRISE_DB_POOL_SIZE=3

# ── Moodle DB (same separate server as enterprise) ────────────────────────────
MOODLE_DB_HOST=your.enterprise.server.ip
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=sabi_readonly_user
MOODLE_DB_PASSWORD=your_moodle_db_password_here
MOODLE_DB_POOL_SIZE=3

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
BASE_URL=http://localhost:8000

# ── School Settings ───────────────────────────────────────────────────────────
SCHOOL_START_TIME=07:30
DEFAULT_MARKING_POLICY_DAYS=7
MIN_STUDENT_FEEDBACK_RESPONSE_RATE=50.0
